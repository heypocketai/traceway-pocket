{
    "name": "traceway/devtesting-symfony",
    "description": "Symfony test application for Traceway via OpenTelemetry",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "symfony/framework-bundle": "^7.0",
        "symfony/routing": "^7.0",
        "symfony/dotenv": "^7.0",
        "symfony/yaml": "^7.0",
        "open-telemetry/sdk": "^1.0",
        "open-telemetry/exporter-otlp": "^1.0",
        "open-telemetry/opentelemetry-auto-symfony": "^1.0",
        "open-telemetry/opentelemetry-auto-pdo": "^0.0",
        "php-http/guzzle7-adapter": "^1.0",
        "google/protobuf": "^4.0",
        "symfony/string": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "tbachert/spi": true
        }
    },
    "scripts": {
        "start": "php -S localhost:8080 public/index.php"
    }
}
